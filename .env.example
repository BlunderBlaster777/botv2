# ============================================================
# Arbitrage Bot – Environment Configuration
# Copy this file to .env and fill in your values.
# NEVER commit .env to source control.
# ============================================================

# --- Network ---
# Polygon PoS RPC endpoint (Infura, Alchemy, or public)
RPC_URL=https://polygon-mainnet.infura.io/v3/YOUR_INFURA_KEY
# Alternatives:
# RPC_URL=https://polygon-mainnet.g.alchemy.com/v2/YOUR_ALCHEMY_KEY
# RPC_URL=https://polygon-rpc.com

# --- Wallet ---
# Dedicated private key for the bot (without 0x prefix is also accepted by ethers)
# Use a fresh wallet with only the funds needed for trading.
PRIVATE_KEY=0xYOUR_PRIVATE_KEY_HERE

# --- Uniswap V3 Contracts (Polygon PoS mainnet) ---
UNISWAP_ROUTER_ADDRESS=0xE592427A0AEce92De3Edee1F18E0157C05861564

# --- Active pairs (comma-separated) ---
# Each name must match the prefix used below (e.g. USDC_WETH, USDC_WMATIC)
ACTIVE_PAIRS=USDC_WETH

# ============================================================
# Pair: USDC / WETH on Polygon
# Pool A: 0.05% fee tier  |  Pool B: 0.30% fee tier
# ============================================================
USDC_WETH_TOKEN_A_ADDRESS=0x2791Bca1f2de4661ED88A30C99A7a9449Aa84174
USDC_WETH_TOKEN_A_SYMBOL=USDC
USDC_WETH_TOKEN_A_DECIMALS=6

USDC_WETH_TOKEN_B_ADDRESS=0x7ceB23fD6bC0adD59E62ac25578270cFf1b9f619
USDC_WETH_TOKEN_B_SYMBOL=WETH
USDC_WETH_TOKEN_B_DECIMALS=18

# Uniswap V3 pool – USDC/WETH 0.05% on Polygon
USDC_WETH_POOL_A_ADDRESS=0x45dDa9cb7c25131DF268515131f647d726f50608
USDC_WETH_POOL_A_FEE=500

# Uniswap V3 pool – USDC/WETH 0.30% on Polygon
USDC_WETH_POOL_B_ADDRESS=0x88f3C15523544835fF6c738DDb30995339AD57d6
USDC_WETH_POOL_B_FEE=3000

# Trade size in USDC (human-readable units, e.g. 100 = 100 USDC)
USDC_WETH_TRADE_SIZE=100

# ============================================================
# Pair: USDC / WMATIC on Polygon  (uncomment to enable)
# Pool A: 0.05% fee tier  |  Pool B: 0.30% fee tier
# ============================================================
# ACTIVE_PAIRS=USDC_WETH,USDC_WMATIC

# USDC_WMATIC_TOKEN_A_ADDRESS=0x2791Bca1f2de4661ED88A30C99A7a9449Aa84174
# USDC_WMATIC_TOKEN_A_SYMBOL=USDC
# USDC_WMATIC_TOKEN_A_DECIMALS=6

# USDC_WMATIC_TOKEN_B_ADDRESS=0x0d500B1d8E8eF31E21C99d1Db9A6444d3ADf1270
# USDC_WMATIC_TOKEN_B_SYMBOL=WMATIC
# USDC_WMATIC_TOKEN_B_DECIMALS=18

# Uniswap V3 pool – USDC/WMATIC 0.05% on Polygon
# USDC_WMATIC_POOL_A_ADDRESS=0xA374094527e1673A86dE625aa59517c5dE346d32
# USDC_WMATIC_POOL_A_FEE=500

# Uniswap V3 pool – USDC/WMATIC 0.30% on Polygon
# USDC_WMATIC_POOL_B_ADDRESS=0x0e44cEb592AcFC5D3F09D996302eB4C499ff8c10
# USDC_WMATIC_POOL_B_FEE=3000

# USDC_WMATIC_TRADE_SIZE=100

# ============================================================
# Bot Parameters
# ============================================================

# Minimum price difference (%) between the two pools to trigger a trade
# Default: 0.5 — only trade when pools diverge by at least 0.5%
MIN_PROFIT_THRESHOLD_PERCENT=0.5

# Maximum allowed slippage per swap (%)
# Default: 0.5
MAX_SLIPPAGE_PERCENT=0.5

# How often to poll prices (milliseconds)
# Default: 5000 (5 seconds)
POLL_INTERVAL_MS=5000

# Dry-run mode: set to "true" to simulate only (no real transactions)
# Always start with dry-run=true to verify the bot behaves correctly.
DRY_RUN=true
